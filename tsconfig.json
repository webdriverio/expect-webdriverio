{
  /**
  * Let's aligned with the WebdriverIO tsconfig.json.
  * @see https://github.com/webdriverio/webdriverio/blob/main/tsconfig.json#L5
  *
  * This configuration is for test and src files, for the build, see the tsconfig.build.json.
  *
  */
  "compilerOptions": {
    "module": "esnext",
    "target": "es2022",
    "lib": ["ES2022", "DOM"],
    "strictBindCallApply": true,
    "removeComments": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": true,
    "strictNullChecks": true,
    "moduleResolution": "bundler", // Can use bundler and omit file extension in test code.
    "allowSyntheticDefaultImports": true,
    "types": [
      "node",
      "@wdio/globals/types"
    ]
  },
  "include": [
    "./src/**/*.ts",
    "__mocks__/**/*.ts",
    "./test/**/*.ts",
  ]
}
