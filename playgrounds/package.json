{
  "name": "expect-wdio-playgrounds",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Playground projects common dependencies",
  "workspaces": ["./jasmine", "./jest", "./mocha"],
  "scripts": {
    "preinstall": "cd .. && npm run compile",
    "setup": "npm install",
    "checks:all": "npm exec --workspaces --call 'npm run checks:all'",
    "snapshots:update": "npm exec --workspace=mocha --call 'npm run snapshots:update'"
  },
  "devDependencies": {
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "@wdio/visual-service": "^9.3.0",
    "eslint": "^9.39.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
